.{
    .fingerprint = 0x9cd73c2cb5d6d1eb,
    .name = .labelle_bgfx,
    .version = "0.1.0",
    .minimum_zig_version = "0.16.0",
    .dependencies = .{
        // Pinned to specific commits — same class of fix as #146.
        // Bumping either dep requires `zig fetch <new-url>` to get
        // the new hash, then updating the url and hash together.
        .zbgfx = .{
            .url = "https://codeberg.org/cyberegoorg/zbgfx/archive/8f01ea0ab6.tar.gz",
            .hash = "zbgfx-0.12.0-Sm4IxEuHywb45XqoIhv3iEOxKXc01aKNNVjI63FHvqFw",
        },
        .zglfw = .{
            .url = "https://github.com/zig-gamedev/zglfw/archive/0dd29d8073487c9fe1e45e6b729b3aac271d5a71.tar.gz",
            .hash = "zglfw-0.10.0-dev-zgVDNIG4IQBWN_sfMD-xfC9bJS2hbBN2W7jNlDLovcdC",
        },
        // Shared Android gamepad source (#310 Stage 4). In-tree sub-package
        // shared with the sokol backend: the per-device STATE machine
        // (`android_gamepad_state.zig`, #250) as the `android_gamepad` module,
        // plus the InputManager JNI DETECTION glue (`android_gamepad_jni.c`,
        // #248) reached via `dep.path(...)` and compiled into `input` on
        // Android. Off Android nothing here is referenced.
        .labelle_android_gamepad = .{
            .path = "android_gamepad",
        },
        // Shared windowless-SDL desktop gamepad source (core#28). In-tree
        // sub-package shared with the raylib and sokol desktop backends via a
        // relative path. On desktop targets, bgfx's `input` routes the gamepad
        // getters through this SDL HIDAPI source (so Switch-mode pads read)
        // instead of GLFW. The assembler stages it under .labelle/deps/ only
        // when `.gamepad = .auto`; off Android/desktop-disabled nothing here is
        // referenced.
        .labelle_sdl_gamepad = .{
            .path = "sdl_gamepad",
        },
        // labelle-core (#310 Stage 4 + #386 Phase 3). The bgfx Android backend
        // adapter (`src/android.zig`) imports core for the `AndroidBackendContext`
        // type it hands to `registerAndroidBackend`; `src/window.zig` and
        // `src/input.zig` additionally import it to PROVE contract conformance at
        // comptime (`core.assertWindow` / `core.assertInput`). Those asserts are
        // comptime-only (no core types cross the engine seam), so they need no
        // codegen unification. The generated build still `overrideImport`s the
        // app's unified core onto the bgfx `input` module on Android so the
        // registered vtable's type matches the engine's; this pin resolves the
        // standalone compile-check. v1.21.0 carries the canonical window contract
        // (`window_contract.zig` - width/height/frameDuration/requestQuit), the
        // unification target for the beginDrawing->beginFrame / getScreenWidth->
        // width / windowShouldClose->shouldQuit renames in this backend.
        .labelle_core = .{
            .url = "https://github.com/labelle-toolkit/labelle-core/archive/refs/tags/v1.21.0.tar.gz",
            .hash = "labelle_core-1.21.0-OauRcIB7BQBRlGRQ111DQ1GC5PeFe2hzO-_9pIsULCzJ",
        },
        // Shared audio engine (pluggable-backends RFC, Phase 2). The bgfx
        // backend's `src/audio.zig` collapses its duplicated WAV decode + PCM
        // mixer onto `labelle_audio.Mixer(Sink)`, keeping only its real OS
        // device code (miniaudio desktop / AAudio Android) adapted to the
        // shared `DeviceSink` contract. In-tree sibling checkout (own-build.zig
        // sub-package), reached via a relative path like the other shared
        // sub-packages above. The generated app build must also wire this dep
        // onto the `audio` module (see CLAUDE notes / report).
        .labelle_audio = .{
            .url = "https://github.com/labelle-toolkit/labelle-audio/archive/refs/tags/v0.2.1.tar.gz",
            .hash = "labelle_audio-0.2.1-QQRmYI4eAQDChv7DVK74-HPS9_J2bJw5ZDKFOazffYjU",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        // Assembler-consumed at codegen time (pluggable-backends #386):
        "backend.manifest.zon",
        "build_fragments",
        "templates",
        // Build inputs:
        "src",
        "libs",
        // Vendored shared gamepad sub-packages (formerly the in-tree
        // backends/sdl_gamepad + backends/android_gamepad referenced via `../`).
        // Vendored so this out-of-tree package is self-contained; de-duplicating
        // them into standalone repos shared with raylib/sokol is a follow-up.
        "sdl_gamepad",
        "android_gamepad",
    },
}
